<?php

namespace {{namespace}}\Exceptions;

use Symfony\Component\HttpKernel\Exception\HttpException;

class SocialAuthenticationException extends HttpException
{
    public function __construct(string $message = 'Social authentication failed.', ?\Throwable $previous = null, int $code = 0, array $headers = [])
    {
        parent::__construct(401, $message, $previous, $headers, $code);
    }
}
