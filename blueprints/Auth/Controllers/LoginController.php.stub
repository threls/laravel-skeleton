<?php

namespace App\Http\Api\Auth\Controllers;

use {{namespace}}\Actions\LoginAction;
use {{namespace}}\Data\LoginData;
use App\Http\Api\Auth\Requests\LoginRequest;
use App\Http\Controllers\Controller;
use Illuminate\Contracts\Support\Responsable;

class LoginController extends Controller
{
    public function __invoke(LoginRequest $request, LoginAction $action): Responsable
    {
        return $action->execute(LoginData::from($request));
    }
}
