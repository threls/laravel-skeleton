<?php

namespace App\Http\Api\Auth\Controllers;

use {{namespace}}\Actions\ForgotPasswordAction;
use App\Http\Api\Auth\Requests\ForgotPasswordRequest;
use App\Http\Controllers\Controller;
use Illuminate\Contracts\Support\Responsable;

class ForgotPasswordController extends Controller
{
    public function __invoke(ForgotPasswordRequest $request, ForgotPasswordAction $action): Responsable
    {
        return $action->execute($request->email);
    }
}
