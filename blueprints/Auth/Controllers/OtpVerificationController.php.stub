<?php

namespace App\Http\Api\Auth\Controllers;

use {{namespace}}\Actions\VerifyOtpAction;
use {{namespace}}\Data\OtpData;
use App\Http\Controllers\Controller;
use App\Http\Api\Auth\Requests\VerifyOtpRequest;
use Illuminate\Contracts\Support\Responsable;

class OtpVerificationController extends Controller
{
    public function __invoke(VerifyOtpRequest $request, VerifyOtpAction $action): Responsable
    {
        return $action->execute($request->user(), OtpData::from($request));
    }
}
