<?php

namespace App\Http\Api\Auth\Controllers;

use {{namespace}}\Actions\RegisterAction;
use {{namespace}}\Data\RegisterData;
use App\Http\Controllers\Controller;
use Illuminate\Contracts\Support\Responsable;
use App\Http\Api\Auth\Requests\RegisterRequest;

class RegisterController extends Controller
{
    public function __invoke(RegisterRequest $request, RegisterAction $action): Responsable
    {
        return $action->execute(RegisterData::from($request));
    }
}
